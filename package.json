{
  "name": "@jiahe0510/malikraw",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "skills",
    "templates/system",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "malikraw": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "onboard": "node dist/cli.js onboard",
    "cli": "node dist/cli.js",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "restart": "node dist/cli.js restart",
    "status": "node dist/cli.js status",
    "serve": "node dist/cli.js serve",
    "tui": "node dist/cli.js tui",
    "test": "npm run build && node --test $(find dist/test -type f -name '*.test.js')",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.8.2"
  }
}
